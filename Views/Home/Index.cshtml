@model IEnumerable<SUPK.Models.Narudzba>
@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mb-4">
    <h1 class="display-4">Glavna stranica - Master Detail</h1>
    <p>Prikaz narudžbi i njihovih stavki </p>
</div>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-5">
            <h3 class="mb-3">Narudžbe</h3>
            <div class="list-group">
                @foreach(var n in Model)
                {
                    <a href="?id=@n.NarudzbaId" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(Context.Request.Query["id"] == n.NarudzbaId.ToString() ? "active" : "")">
                        <div>
                            <strong>Narudžba ID:</strong> @n.NarudzbaId <br/>
                            <strong>Račun ID:</strong> @n.RacunId <br/>
                            <strong>Vrijeme:</strong> @n.VrijemeNarudzbe.ToString("g") <br/>
                        </div>
                        <span class="btn btn-sm @(Context.Request.Query["id"] == n.NarudzbaId.ToString() ? "btn-light" : "btn-primary")">Pokaži stavke</span>
                    </a>
                }
            </div>
        </div>
        <div class="col-md-7">
            <h3 class="mb-3">Odabrana narudžba</h3>
            @{
                var selectedIdText = Context.Request.Query["id"];
                if(!string.IsNullOrEmpty(selectedIdText) && int.TryParse(selectedIdText, out int selectedId))
                {
                    var selectedNarudzba = Model.FirstOrDefault(x => x.NarudzbaId == selectedId);
                    if(selectedNarudzba != null)
                    {
                        var dbContext = new SUPK.Models.CaffeBarDbContext();
                        var stavke = dbContext.Stavkanarudzbes.Where(s => s.NarudzbaId == selectedId).ToList();
                        
                        <div class="card shadow-sm">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0">Detalji za Narudžbu ID: @selectedId</h5>
                            </div>
                            <div class="card-body p-0">
                                @if(stavke.Any())
                                {
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Stavka ID</th>
                                                <th>Proizvod ID</th>
                                                <th>Količina</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach(var s in stavke)
                                            {
                                                <tr>
                                                    <td>@s.StavkaId</td>
                                                    <td>@s.ProizvodId</td>
                                                    <td>@s.Kolicina</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                                else
                                {
                                    <div class="p-3 text-muted text-center">Nema stavki za ovu narudžbu.</div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-info" role="alert">
                        Odaberite narudžbu s popisa za prikaz njezinih stavki.
                    </div>
                }
            }
        </div>
    </div>
</div>
