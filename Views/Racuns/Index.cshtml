@model IEnumerable<SUPK.Models.Racun>

@{
    ViewData["Title"] = "Popis računa";
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-3">
    <h1 class="h3 mb-0 text-gray-800">Računi</h1>
    <a asp-action="Create" class="btn btn-success d-flex align-items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-lg me-2" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2Z"/>
        </svg>
        Novi račun
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                <thead class="table-light">
                    <tr>
                        <th>Otvoren</th>
                        <th>Zatvoren</th>
                        <th>Ukupno (€)</th>
                        <th>Konobar</th>
                        <th>Stol</th>
                        <th class="text-center">Akcije</th>
                    </tr>
                </thead>
                <tbody>
            @foreach (var item in Model) {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.VrijemeOtvaranja)</td>
                        <td>@(item.VrijemeZatvaranja.HasValue ? item.VrijemeZatvaranja.Value.ToString("dd.MM.yyyy HH:mm") : "-")</td>
                        <td class="fw-bold">@item.UkupnaCijena €</td>
                        <td>@(item.Konobar?.Ime ?? "N/A")</td>
                        <td>@item.Stol?.BrojStola</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.RacunId" class="btn btn-sm btn-primary">Uredi</a>
                            <a asp-action="Details" asp-route-id="@item.RacunId" class="btn btn-sm btn-info text-white">Detalji</a>
                            <a asp-action="Delete" asp-route-id="@item.RacunId" class="btn btn-sm btn-danger">Obriši</a>
                        </td>
                    </tr>
            }
                </tbody>
            </table>
        </div>
    </div>
</div>
