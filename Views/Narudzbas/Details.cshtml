@model SUPK.Models.Narudzba

@{
    ViewData["Title"] = "Detalji narudžbe";
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-3">
    <h1 class="h3 mb-0 text-gray-800">Detalji narudžbe</h1>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Osnovni podaci</h6>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 fw-bold">Vrijeme narudžbe</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.VrijemeNarudzbe)</dd>

            <dt class="col-sm-3 fw-bold">Broj računa</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Racun.RacunId)</dd>
        </dl>
    </div>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-info">Stavke narudžbe</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-bordered mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Proizvod</th>
                        <th>Količina</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Stavkanarudzbes != null && Model.Stavkanarudzbes.Any())
                    {
                        foreach (var stavka in Model.Stavkanarudzbes)
                        {
                            <tr>
                                <td>@stavka.Proizvod?.Naziv</td>
                                <td>@stavka.Kolicina</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="2" class="text-center text-muted p-3">Ova narudžba nema stavki.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model?.NarudzbaId" class="btn btn-primary">Uredi</a>
    <a asp-action="Index" class="btn btn-secondary ms-2">Natrag na listu</a>
</div>
