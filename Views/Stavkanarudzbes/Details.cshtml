@model SUPK.Models.Stavkanarudzbe

@{
    ViewData["Title"] = "Detalji stavke narudžbe";
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-3">
    <h1 class="h3 mb-0 text-gray-800">Detalji stavke narudžbe</h1>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Osnovni podaci</h6>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 fw-bold">Količina</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Kolicina)</dd>
            
            <dt class="col-sm-3 fw-bold">Broj narudžbe</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Narudzba.NarudzbaId)</dd>
            
            <dt class="col-sm-3 fw-bold">ID proizvoda</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Proizvod.ProizvodId)</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model?.StavkaId" class="btn btn-primary">Uredi</a>
    <a asp-action="Index" class="btn btn-secondary ms-2">Natrag na listu</a>
</div>
