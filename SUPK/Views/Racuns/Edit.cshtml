@model SUPK.ViewModels.RacunEditViewModel

@{
    ViewData["Title"] = "Uredi račun";
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-3">
    <h1 class="h3 mb-0 text-gray-800">Uredi račun #@Model.Racun.RacunId</h1>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Osnovni podaci računa</h6>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Racun.RacunId" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Racun.VrijemeOtvaranja" class="form-label fw-bold">Vrijeme otvaranja</label>
                    <input asp-for="Racun.VrijemeOtvaranja" class="form-control" type="datetime-local" />
                    <span asp-validation-for="Racun.VrijemeOtvaranja" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Racun.VrijemeZatvaranja" class="form-label fw-bold">Vrijeme zatvaranja</label>
                    <input asp-for="Racun.VrijemeZatvaranja" class="form-control" type="datetime-local" />
                    <span asp-validation-for="Racun.VrijemeZatvaranja" class="text-danger small"></span>
                    <div class="form-text">Ostavite prazno ako račun još nije zatvoren.</div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Racun.StolId" class="form-label fw-bold">Stol</label>
                    <select asp-for="Racun.StolId" class="form-select" asp-items="ViewBag.StolId"></select>
                    <span asp-validation-for="Racun.StolId" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Racun.KonobarId" class="form-label fw-bold">Konobar</label>
                    <select asp-for="Racun.KonobarId" class="form-select" asp-items="ViewBag.KonobarId"></select>
                    <span asp-validation-for="Racun.KonobarId" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Racun.NacinPlacanja" class="form-label">Način plaćanja</label>
                    <select asp-for="Racun.NacinPlacanja" asp-items="ViewBag.NacinPlacanja" class="form-select">
                        <option value="">-- Odaberite način plaćanja --</option>
                    </select>
                    <span asp-validation-for="Racun.NacinPlacanja" class="text-danger"></span>
                </div>
            </div>

            <hr />

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="m-0 font-weight-bold text-primary">Narudžbe </h6>
                <div class="btn-spacing-group">
                    <button type="button" id="dodajNarudzbu" class="btn btn-sm btn-outline-primary">+ Dodaj narudžbu</button>
                </div>
            </div>

            <div id="narudzbeContainer">
                @for (int ni = 0; ni < Model.Narudzbe.Count; ni++)
                {
                    <div class="card mb-3 narudzba-block">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="mb-0">Narudžba #@Model.Narudzbe[ni].NarudzbaId</h6>
                                <button type="button" class="btn btn-sm btn-outline-danger obrisi-narudzbu">Obriši narudžbu</button>
                            </div>

                            <input type="hidden" asp-for="Narudzbe[@ni].NarudzbaId" />

                            <div class="mb-2">
                                <label class="form-label small">Vrijeme narudžbe</label>
                                <input asp-for="Narudzbe[@ni].VrijemeNarudzbe" asp-format="{0:yyyy-MM-ddTHH:mm}" class="form-control narudzba-datetime" type="datetime-local" step="60" />
                            </div>

                            <table class="table table-sm table-bordered mb-0">
                                <thead>
                                    <tr>
                                        <th>Proizvod</th>
                                        <th style="width:120px">Količina</th>
                                        <th style="width:50px"></th>
                                    </tr>
                                </thead>
                                <tbody class="stavkeContainer">
                                    @for (int si = 0; si < Model.Narudzbe[ni].Stavke.Count; si++)
                                    {
                                        <tr class="stavka-red">
                                            <td>
                                                <input type="hidden" asp-for="Narudzbe[@ni].Stavke[@si].StavkaId" />
                                                <select asp-for="Narudzbe[@ni].Stavke[@si].ProizvodId" asp-items="ViewBag.Proizvodi" class="form-select proizvod-select"></select>
                                            </td>
                                            <td>
                                                <input asp-for="Narudzbe[@ni].Stavke[@si].Kolicina" class="form-control" type="number" min="1" />
                                            </td>
                                            <td class="text-center align-middle">
                                                <button type="button" class="btn btn-sm btn-danger obrisi-stavku">X</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="3" class="text-end">
                                            <button type="button" class="btn btn-sm btn-outline-success dodaj-stavku">+ Dodaj stavku</button>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                }
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary px-4">Spremi promjene</button>
                <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary ms-2">Odustani</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(function () {
            function nowForDateTimeLocal() {
                var d = new Date();
                var yyyy = d.getFullYear();
                var mm = String(d.getMonth() + 1).padStart(2, '0');
                var dd = String(d.getDate()).padStart(2, '0');
                var hh = String(d.getHours()).padStart(2, '0');
                var mi = String(d.getMinutes()).padStart(2, '0');
                return `${yyyy}-${mm}-${dd}T${hh}:${mi}`;
            }

            // helper to get options HTML for dynamic rows
            var proizvodOptions = $('.proizvod-select').first().html() || '';

            // Add new narudzba block
            $('#dodajNarudzbu').click(function () {
                var nIndex = $('.narudzba-block').length;
                var now = nowForDateTimeLocal();
                var block = `
                <div class="card mb-3 narudzba-block">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="mb-0">Nova narudžba</h6>
                            <button type="button" class="btn btn-sm btn-outline-danger obrisi-narudzbu">Obriši narudžbu</button>
                        </div>
                        <input type="hidden" name="Narudzbe[${nIndex}].NarudzbaId" value="" />
                        <div class="mb-2">
                            <label class="form-label small">Vrijeme narudžbe</label>
                            <input name="Narudzbe[${nIndex}].VrijemeNarudzbe" value="${now}" class="form-control narudzba-datetime" type="datetime-local" step="60" />
                        </div>
                        <table class="table table-sm table-bordered mb-0">
                            <thead>
                                <tr><th>Proizvod</th><th style="width:120px">Količina</th><th style="width:50px"></th></tr>
                            </thead>
                            <tbody class="stavkeContainer">
                                <tr class="stavka-red">
                                    <td>
                                        <input type="hidden" name="Narudzbe[${nIndex}].Stavke[0].StavkaId" value="" />
                                        <select name="Narudzbe[${nIndex}].Stavke[0].ProizvodId" class="form-select proizvod-select">${proizvodOptions}</select>
                                    </td>
                                    <td><input name="Narudzbe[${nIndex}].Stavke[0].Kolicina" class="form-control" type="number" value="1" min="1" /></td>
                                    <td class="text-center"><button type="button" class="btn btn-sm btn-danger obrisi-stavku">X</button></td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr><td colspan="3" class="text-end"><button type="button" class="btn btn-sm btn-outline-success dodaj-stavku">+ Dodaj stavku</button></td></tr>
                            </tfoot>
                        </table>
                    </div>
                </div>`;

                $('#narudzbeContainer').append(block);
            });

            // Delegate add stavku inside its narudzba block
            $(document).on('click', '.dodaj-stavku', function () {
                var block = $(this).closest('.narudzba-block');
                var nIndex = $('.narudzba-block').index(block);
                var sIndex = block.find('.stavka-red').length;

                var row = `
                    <tr class="stavka-red">
                        <td>
                            <input type="hidden" name="Narudzbe[${nIndex}].Stavke[${sIndex}].StavkaId" value="" />
                            <select name="Narudzbe[${nIndex}].Stavke[${sIndex}].ProizvodId" class="form-select proizvod-select">${proizvodOptions}</select>
                        </td>
                        <td>
                            <input name="Narudzbe[${nIndex}].Stavke[${sIndex}].Kolicina" class="form-control" type="number" value="1" min="1" />
                        </td>
                        <td class="text-center"><button type="button" class="btn btn-sm btn-danger obrisi-stavku">X</button></td>
                    </tr>
                `;
                block.find('.stavkeContainer').append(row);
            });

            // Delete stavka
            $(document).on('click', '.obrisi-stavku', function () {
                var block = $(this).closest('.narudzba-block');
                if (block.find('.stavka-red').length > 1) {
                    $(this).closest('tr').remove();
                    // reindex names inside this block
                    reindexBlock(block);
                } else {
                    alert('Narudžba mora imati barem jednu stavku!');
                }
            });

            // Delete narudzba
            $(document).on('click', '.obrisi-narudzbu', function () {
                if ($('.narudzba-block').length > 1) {
                    $(this).closest('.narudzba-block').remove();
                    reindexAll();
                } else {
                    if (confirm('Želite obrisati jedinu narudžbu? Ovo će obrisati i sve njezine stavke.')) {
                        $(this).closest('.narudzba-block').remove();
                        reindexAll();
                    }
                }
            });

            function reindexBlock(block) {
                var nIndex = $('.narudzba-block').index(block);
                block.find('.stavka-red').each(function (sIndex) {
                    $(this).find('input[type=hidden]').attr('name', `Narudzbe[${nIndex}].Stavke[${sIndex}].StavkaId`);
                    $(this).find('select.proizvod-select').attr('name', `Narudzbe[${nIndex}].Stavke[${sIndex}].ProizvodId`).attr('id', `Narudzbe_${nIndex}__Stavke_${sIndex}__ProizvodId`);
                    $(this).find('input[type=number]').attr('name', `Narudzbe[${nIndex}].Stavke[${sIndex}].Kolicina`).attr('id', `Narudzbe_${nIndex}__Stavke_${sIndex}__Kolicina`);
                });
            }

            function reindexAll() {
                $('.narudzba-block').each(function (nIndex) {
                    $(this).find('input[name$=".NarudzbaId"]').attr('name', `Narudzbe[${nIndex}].NarudzbaId`);
                    $(this).find('.narudzba-datetime').first().attr('name', `Narudzbe[${nIndex}].VrijemeNarudzbe`);
                    reindexBlock($(this));
                });
            }
        });
    </script>
}
